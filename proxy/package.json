{
  "name": "claudebridge-proxy",
  "version": "0.2.0",
  "description": "CLI orchestrator: headless Claude Code agent via relay, consumed by Chromattica desktop and Android app",
  "type": "module",
  "main": "dist/orchestrator.js",
  "bin": {
    "claude-bridge": "./bin/claude-bridge.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/orchestrator.ts",
    "start": "node dist/orchestrator.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
