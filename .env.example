# =============================================================================
# ClaudeBridge — Node proxy (legacy stream-JSON orchestrator) configuration
# =============================================================================
# These vars are read by proxy/src/config.ts. The primary host is the
# Chromattica desktop app (which manages its own config); this .env is only
# for running the standalone legacy proxy in proxy/.

# --- Relay (required) ---

# WebSocket URL of YOUR self-hosted relay (bring your own — host it anywhere).
# Use the wss:// URL it's reachable at, e.g. wss://relay.example.com
RELAY_URL=wss://your-relay-host.example.com

# Connection token. Your relay should run in pairing mode (RELAY_ALLOW_PAIRING=1),
# which accepts any non-empty token and scopes channels to it. Pick any value;
# treat it as the secret that gates access to your channels.
RELAY_AUTH_TOKEN=

# --- Optional ---

# Model for proxy-run sessions. Defaults to "sonnet" if unset.
CLAUDE_MODEL=sonnet

# Permission mode for proxy-run sessions. Defaults to "default" if unset.
PERMISSION_MODE=default
