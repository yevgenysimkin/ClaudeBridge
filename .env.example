# =============================================================================
# ClaudeBridge Environment Configuration
# =============================================================================

# --- Relay Server ---

# URL of the WebSocket relay (Railway deployment)
RELAY_URL=https://cb.pinewell.xyz

# Shared auth token (same value must be set on the Railway relay service)
RELAY_AUTH_TOKEN=

# --- Anthropic (optional) ---

# API key for Claude Agent SDK sessions.
# If unset, the SDK falls back to your existing Claude Code CLI auth (Max plan).
ANTHROPIC_API_KEY=

# Model to use for agent sessions (default: claude-sonnet-4-5-20250929)
CLAUDE_MODEL=claude-sonnet-4-5-20250929
