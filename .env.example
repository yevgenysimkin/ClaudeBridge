# =============================================================================
# ClaudeBridge Environment Configuration
# =============================================================================
# Run ./scripts/setup.sh to populate most of these automatically.

# --- Matrix / Synapse ---

# Synapse registration shared secret (generated during Railway deploy or local setup)
SYNAPSE_REGISTRATION_SECRET=

# Matrix homeserver URL
# Railway:  https://your-project-production-xxxx.up.railway.app
# Local:    http://localhost:8008
MATRIX_HOMESERVER_URL=

# Bot user credentials (created by setup.sh)
MATRIX_BOT_USER=@bridge-bot:claudebridge
MATRIX_BOT_ACCESS_TOKEN=

# Admin user (created by setup.sh, invited to all rooms)
MATRIX_ADMIN_USER=@ysimkin:claudebridge

# --- Anthropic ---

# API key for Claude Agent SDK sessions
ANTHROPIC_API_KEY=

# Model to use for agent sessions (default: claude-sonnet-4-5-20250929)
CLAUDE_MODEL=claude-sonnet-4-5-20250929
